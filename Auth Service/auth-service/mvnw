#!/bin/sh
set -e

# Minimal mvnw that downloads the Takari maven-wrapper jar when needed
PRG="$0"
SCRIPT_DIR=`dirname "$PRG"`
WRAPPER_DIR="$SCRIPT_DIR/.mvn/wrapper"
JAR="$WRAPPER_DIR/maven-wrapper.jar"

if [ ! -f "$JAR" ]; then
  mkdir -p "$WRAPPER_DIR"
  echo "Downloading maven-wrapper.jar..."
  URL="https://repo1.maven.org/maven2/io/takari/maven-wrapper/0.5.6/maven-wrapper-0.5.6.jar"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL -o "$JAR" "$URL"
  elif command -v wget >/dev/null 2>&1; then
    wget -q -O "$JAR" "$URL"
  else
    echo "Error: curl or wget is required to bootstrap the Maven wrapper." >&2
    exit 1
  fi
fi

exec java -jar "$JAR" "$@"
